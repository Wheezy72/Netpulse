# ==========================================
# NETPULSE ENVIRONMENT CONFIGURATION
# ==========================================

# --- Security ---
SECRET_KEY=change-me-to-a-random-string
ENVIRONMENT=development

# --- Database Credentials (REQUIRED for PgBouncer & App) ---
POSTGRES_USER=netpulse
POSTGRES_PASSWORD=netpulse_secure_pass
POSTGRES_DB=netpulse

# --- Network Monitoring Targets ---
PULSE_GATEWAY_IP=192.168.1.1    # Change this if your ip route gateway is different
PULSE_ISP_IP=8.8.8.8
PULSE_CLOUDFLARE_IP=1.1.1.1

# --- Rust Probe Configuration (REQUIRED) ---
PROBE_IFACE=eth0                # Change to wlan0 if using WiFi natively instead of NAT

# --- Frontend CORS Configuration ---
# Allows the Vue frontend (on custom port 6969 or fallbacks) to talk to the FastAPI backend
CORS_ALLOW_ORIGINS=http://localhost:8000,http://localhost:6969,http://localhost:6970,http://localhost:5173

# --- External APIs (Optional) ---
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_OAUTH_CLIENT_ID=...
# GOOGLE_OAUTH_CLIENT_SECRET=...
# ABUSEIPDB_API_KEY=...

# --- Rogue DHCP Detection (Optional) ---
# ALLOWED_DHCP_SERVER_MACS=aa:bb:cc:dd:ee:ff,11:22:33:44:55:66

# --- Storage (Optional) ---
# PCAP_STORAGE_DIR=/tmp/pcaps
